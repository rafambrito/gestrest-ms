	"item": [
		{
			"name": "1. Tipos de Usuário",
			"item": [
				{
					"name": "Criar Tipo FORNECEDOR",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
									"pm.test(\"Response has id\", function () { var json = pm.response.json(); pm.expect(json).to.have.property('id'); });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nome\": \"FORNECEDOR\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/tipos-usuarios", "host": ["{{base_url}}"], "path": ["api", "v1", "tipos-usuarios"] }
					}
				},
				{
					"name": "Listar Tipos",
					"event": [ { "listen": "test", "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"] } } ],
					"request": { "method": "GET", "url": { "raw": "{{base_url}}/api/v1/tipos-usuarios", "host": ["{{base_url}}"], "path": ["api", "v1", "tipos-usuarios"] } }
				},
				{
					"name": "Buscar Tipo por ID",
					"event": [ { "listen": "test", "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"] } } ],
					"request": { "method": "GET", "url": { "raw": "{{base_url}}/api/v1/tipos-usuarios/1", "host": ["{{base_url}}"], "path": ["api", "v1", "tipos-usuarios", "1"] } }
				},
				{
					"name": "Atualizar Tipo",
					"event": [ { "listen": "test", "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"] } } ],
					"request": {
						"method": "PUT",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"FORNECEDOR_ATUALIZADO\"\n}", "options": { "raw": { "language": "json" } } },
						"url": { "raw": "{{base_url}}/api/v1/tipos-usuarios/3", "host": ["{{base_url}}"], "path": ["api", "v1", "tipos-usuarios", "3"] }
					}
				},
				{
					"name": "Deletar Tipo",
					"event": [ { "listen": "test", "script": { "exec": ["pm.test(\"Status code is 204 or 200\", function () { pm.expect([200,204]).to.include(pm.response.code); });"] } } ],
					"request": { "method": "DELETE", "url": { "raw": "{{base_url}}/api/v1/tipos-usuarios/3", "host": ["{{base_url}}"], "path": ["api", "v1", "tipos-usuarios", "3"] } }
				}
			]
		},
