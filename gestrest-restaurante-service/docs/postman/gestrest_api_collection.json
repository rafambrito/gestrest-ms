					"request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Fiap Gourmet Atualizado\",\n  \"endereco\": \"Av. Paulista, 1100\",\n  \"tipoCozinha\": \"Italiana\",\n  \"horarioFuncionamento\": \"11:00 - 23:00\"\n}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{base_url}}/api/v1/restaurantes/1", "host": ["{{base_url}}"], "path": ["api", "v1", "restaurantes", "1"] } },
